{
  "schema": "katana-quality-profiles",
  "version": 1,
  "profiles": [
    {
      "id": "local-debug-gate",
      "active": true,
      "owner": "KR-3701",
      "configure_preset": "debug-gate",
      "build_preset": "debug-gate",
      "test_preset": "debug-gate"
    },
    {
      "id": "sanitizers",
      "active": true,
      "owner": "KR-3702",
      "configure_preset": "sanitizer-debug",
      "build_preset": "sanitizer-debug",
      "test_preset": "sanitizer-debug",
      "implementations": {
        "msvc": "address",
        "gcc-clang": "address,undefined"
      }
    },
    {
      "id": "fuzzing",
      "active": true,
      "owner": "KR-3703",
      "configure_preset": "fuzz-debug",
      "build_preset": "fuzz-debug",
      "test_preset": "fuzz-debug",
      "targets": ["decoder", "loader", "ir", "runtime"],
      "synthetic_only": true
    },
    {
      "id": "coverage",
      "active": true,
      "owner": "KR-3704",
      "configure_preset": "coverage-debug",
      "build_preset": "coverage-debug",
      "test_preset": "coverage-debug",
      "report_script": "tools/quality/write-coverage-report.ps1",
      "output": "build-current/coverage/coverage.cobertura.xml",
      "backends": ["msvc-dynamic", "gcov"]
    },
    {
      "id": "format-static-analysis",
      "active": true,
      "owner": "KR-3705",
      "configure_preset": "quality-debug",
      "build_preset": "quality-debug",
      "test_preset": "quality-debug",
      "format_check_script": "tools/quality/check-format.ps1",
      "analysis_backends": ["msvc-analyze", "clang-tidy"],
      "warnings_as_errors": true
    },
    {
      "id": "artifact-audit",
      "active": true,
      "owner": "KR-3706",
      "configure_preset": "artifact-debug",
      "build_preset": "artifact-debug",
      "test_preset": "artifact-debug",
      "package_script": "tools/quality/write-reproducible-artifact.ps1",
      "output": "build-current/artifacts",
      "double_generation_required": true,
      "private_inputs_forbidden": true
    },
    {
      "id": "reference-license-audit",
      "active": true,
      "owner": "KR-3709",
      "audit_script": "tools/quality/audit-reference-provenance.ps1",
      "fixture_manifest": "tests/fixtures/reference_audit_forbidden_paths.txt",
      "synthetic_markers_only": true,
      "project_license_decision": "required-before-external-release"
    },
    {
      "id": "phase8-gate-preparation",
      "active": true,
      "owner": "KR-3709",
      "gate_script": "tools/gates/run-phase8-preparation.ps1",
      "configure_preset": "artifact-debug",
      "single_fresh_build": true,
      "single_coverage_regression": true
    },
    {
      "id": "release-build",
      "active": false,
      "owner": "KR-4999"
    },
    {
      "id": "windows-linux-ci",
      "active": false,
      "owner": "KR-4901",
      "activation_owner": "KR-4999"
    }
  ]
}
