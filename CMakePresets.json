{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug-gate",
      "displayName": "KatanaRecomp local Debug gate",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-current",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "sanitizer-debug",
      "displayName": "KatanaRecomp sanitizer Debug gate",
      "inherits": "debug-gate",
      "cacheVariables": {
        "KATANA_ENABLE_SANITIZERS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug-gate",
      "configurePreset": "debug-gate"
    },
    {
      "name": "sanitizer-debug",
      "configurePreset": "sanitizer-debug"
    }
  ],
  "testPresets": [
    {
      "name": "debug-gate",
      "configurePreset": "debug-gate",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "sanitizer-debug",
      "configurePreset": "sanitizer-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      },
      "environment": {
        "ASAN_OPTIONS": "halt_on_error=1",
        "UBSAN_OPTIONS": "halt_on_error=1:print_stacktrace=1"
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "debug-gate",
      "displayName": "Configure, build and test the local Debug gate",
      "steps": [
        {
          "type": "configure",
          "name": "debug-gate"
        },
        {
          "type": "build",
          "name": "debug-gate"
        },
        {
          "type": "test",
          "name": "debug-gate"
        }
      ]
    },
    {
      "name": "sanitizer-debug",
      "displayName": "Configure, build and test the sanitizer Debug gate",
      "steps": [
        {
          "type": "configure",
          "name": "sanitizer-debug"
        },
        {
          "type": "build",
          "name": "sanitizer-debug"
        },
        {
          "type": "test",
          "name": "sanitizer-debug"
        }
      ]
    }
  ]
}
