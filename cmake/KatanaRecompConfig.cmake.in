@PACKAGE_INIT@

set(KatanaRecomp_VERSION "@KATANA_PROJECT_VERSION@")
set(KatanaRecomp_RUNTIME_ABI_VERSION "@KATANA_RUNTIME_ABI_VERSION@")
set(KatanaRecomp_BLOCK_ABI_VERSION "@KATANA_BLOCK_ABI_VERSION@")
set(KatanaRecomp_PLATFORM_SERVICES_ABI_VERSION "@KATANA_PLATFORM_SERVICES_ABI_VERSION@")
set(KatanaRecomp_BACKEND_INTERFACE_ABI_VERSION "@KATANA_BACKEND_INTERFACE_ABI_VERSION@")
